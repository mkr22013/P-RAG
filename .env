# ──────────────────────────────────────────────────────────────────────────────
# Development Environment
# Non-sensitive config only — secrets come from .env (local) or Key Vault
# Safe to check in
# ──────────────────────────────────────────────────────────────────────────────

APP_ENV=development
OLLAMA_MODEL=llama3.1

# Auth0 left blank — middleware skips validation in dev
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

# Azure services left blank — local fallbacks used automatically
AZURE_BLOB_PDF_CONTAINER=insurance-pdfs
AZURE_BLOB_INDEX_CONTAINER=insurance-indices
AZURE_SERVICE_BUS_QUEUE_NAME=cache-invalidation

# Member API timeouts
MEMBER_API_CONNECT_TIMEOUT=3.0
MEMBER_API_READ_TIMEOUT=10.0
MEMBER_API_MAX_RETRIES=3